{{ 'section-atelier-editorial.css' | asset_url | stylesheet_tag }}

<section class="atelier-editorial color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <header class="atelier-editorial__header">
      <div>
        <span class="atelier-editorial__eyebrow">{{ section.settings.eyebrow | escape }}</span>
        <h2 class="atelier-editorial__heading">{{ section.settings.heading | escape }}</h2>
      </div>
      <p class="atelier-editorial__lead">{{ section.settings.lead }}</p>
    </header>

    <div class="atelier-editorial__grid">
      <article class="atelier-editorial__card atelier-editorial__card--feature atelier-editorial__card--tall">
        <div
          class="atelier-editorial__media"
          style="background-image: url('{{ section.settings.image_url_1 | escape }}');"
          role="img"
          aria-label="{{ section.settings.title_1 | escape }}"
        ></div>
        <div class="atelier-editorial__content">
          <h3 class="atelier-editorial__title">{{ section.settings.title_1 | escape }}</h3>
          <p class="atelier-editorial__copy">{{ section.settings.copy_1 }}</p>
        </div>
      </article>

      <article class="atelier-editorial__card atelier-editorial__card--side">
        <div
          class="atelier-editorial__media"
          style="background-image: url('{{ section.settings.image_url_2 | escape }}');"
          role="img"
          aria-label="{{ section.settings.title_2 | escape }}"
        ></div>
        <div class="atelier-editorial__content">
          <h3 class="atelier-editorial__title">{{ section.settings.title_2 | escape }}</h3>
          <p class="atelier-editorial__copy">{{ section.settings.copy_2 }}</p>
        </div>
      </article>

      <article class="atelier-editorial__card atelier-editorial__card--side">
        <div
          class="atelier-editorial__media"
          style="background-image: url('{{ section.settings.image_url_3 | escape }}');"
          role="img"
          aria-label="{{ section.settings.title_3 | escape }}"
        ></div>
        <div class="atelier-editorial__content">
          <h3 class="atelier-editorial__title">{{ section.settings.title_3 | escape }}</h3>
          <p class="atelier-editorial__copy">{{ section.settings.copy_3 }}</p>
        </div>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Atelier Editorial",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" },
        { "value": "scheme-4", "label": "Scheme 4" },
        { "value": "scheme-5", "label": "Scheme 5" }
      ]
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Editorial"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The modern couture wardrobe"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead text",
      "default": "Sculpted silhouettes, fluid tailoring, and rich materials define Atelier's seasonal point of view."
    },
    {
      "type": "url",
      "id": "image_url_1",
      "label": "Image URL 1",
      "default": "https://images.unsplash.com/photo-1613909671501-f9678ffc1d33?w=1800&auto=format&fit=crop&q=80"
    },
    {
      "type": "text",
      "id": "title_1",
      "label": "Title 1",
      "default": "Statement Outerwear"
    },
    {
      "type": "textarea",
      "id": "copy_1",
      "label": "Copy 1",
      "default": "Hand-finished wool and cashmere layers designed for understated impact."
    },
    {
      "type": "url",
      "id": "image_url_2",
      "label": "Image URL 2",
      "default": "https://images.unsplash.com/photo-1651047666890-8eab731ee345?w=1800&auto=format&fit=crop&q=80"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Title 2",
      "default": "Evening Precision"
    },
    {
      "type": "textarea",
      "id": "copy_2",
      "label": "Copy 2",
      "default": "Bias cuts and polished drape for contemporary occasion dressing."
    },
    {
      "type": "url",
      "id": "image_url_3",
      "label": "Image URL 3",
      "default": "https://images.unsplash.com/photo-1705909237050-7a7625b47fac?w=1800&auto=format&fit=crop&q=80"
    },
    {
      "type": "text",
      "id": "title_3",
      "label": "Title 3",
      "default": "Accessories Studio"
    },
    {
      "type": "textarea",
      "id": "copy_3",
      "label": "Copy 3",
      "default": "Calfskin and suede accents that complete the Atelier silhouette."
    }
  ],
  "presets": [
    {
      "name": "Atelier Editorial"
    }
  ]
}
{% endschema %}
